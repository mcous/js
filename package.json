{
  "name": "@mcous/js",
  "private": true,
  "description": "Monorepo for my base JS configurations.",
  "keywords": [],
  "license": "MIT",
  "author": "Michael Cousins <michael@cousins.io> (https://michael.cousins.io)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcous/js.git"
  },
  "type": "module",
  "scripts": {
    "all": "pnpm build && pnpm lint && pnpm test",
    "build": "pnpm -r --aggregate-output build",
    "format": "eslint . --fix && oxlint . --fix && prettier . --write && oxfmt .",
    "lint": "eslint . && oxlint . && prettier . --check && oxfmt . --check",
    "test": "pnpm -r --aggregate-output test:once"
  },
  "dependencies": {
    "@mcous/eslint-config": "workspace:*",
    "@mcous/oxc-config": "workspace:*",
    "@mcous/prettier-config": "workspace:*",
    "@mcous/typescript-config": "workspace:*"
  },
  "devDependencies": {
    "@oxlint/migrate": "^1.65.0",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vitest-when": "^0.10.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
